# ============================================================================
# Sutradhar configuration (copy to .env and edit). All values have safe
# defaults in sutradhar/core/config.py — nothing here is required to boot.
# Every setting is namespaced with SUTRADHAR_ and nested with __ (double
# underscore), e.g. SUTRADHAR_STT__MODEL_SIZE.
# ============================================================================

# ---- App ----
SUTRADHAR_ENV=local                 # local | ci | prod
SUTRADHAR_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
SUTRADHAR_LOG_JSON=false            # true => JSON logs (prod/CI), false => pretty console
SUTRADHAR_HOST=127.0.0.1
SUTRADHAR_PORT=8080

# ---- Audio ----
SUTRADHAR_AUDIO__SAMPLE_RATE=16000        # browser pipeline default
SUTRADHAR_AUDIO__FRAME_MS=20              # frame size fed to VAD
SUTRADHAR_AUDIO__TELEPHONY_SAMPLE_RATE=8000

# ---- VAD (Silero default; webrtcvad swap) ----
SUTRADHAR_VAD__PROVIDER=silero            # silero | webrtcvad | stub
SUTRADHAR_VAD__THRESHOLD=0.5
SUTRADHAR_VAD__MIN_SILENCE_MS=480         # trailing silence proposing an endpoint

# ---- STT (faster-whisper on GPU; vosk/stub swap) ----
SUTRADHAR_STT__PROVIDER=faster_whisper    # faster_whisper | vosk | stub
SUTRADHAR_STT__MODEL_SIZE=small           # tiny | base | small | medium
SUTRADHAR_STT__DEVICE=cuda                # cuda | cpu (auto-falls back to cpu int8)
SUTRADHAR_STT__COMPUTE_TYPE=int8_float16  # 4GB-friendly on GPU
SUTRADHAR_STT__LANGUAGE=en
SUTRADHAR_STT__EMIT_PARTIALS=false        # GPU: set true for streaming partials (CPU: keep false)

# ---- Turn detector (acoustic + semantic) ----
SUTRADHAR_TURN__PROVIDER=hybrid           # vad_pause | hybrid | stub
SUTRADHAR_TURN__SILENCE_MS=480
SUTRADHAR_TURN__MAX_UTTERANCE_MS=15000
SUTRADHAR_TURN__SEMANTIC_ENABLED=true
SUTRADHAR_TURN__BARGE_IN_MS=150           # confirmed user speech during SPEAKING that interrupts

# ---- LLM (Ollama / Qwen2.5-3B; openai-compatible stub swap) ----
SUTRADHAR_LLM__PROVIDER=ollama            # ollama | openai_compatible | stub
SUTRADHAR_LLM__MODEL=qwen2.5:3b-instruct-q4_K_M
SUTRADHAR_LLM__BASE_URL=http://127.0.0.1:11434
SUTRADHAR_LLM__TEMPERATURE=0.4
SUTRADHAR_LLM__MAX_TOKENS=512
SUTRADHAR_LLM__NUM_CTX=4096
SUTRADHAR_LLM__KEEP_ALIVE=30m             # keep the model resident so turns stay fast

# ---- TTS (Piper default; Kokoro optional; cloud stub swap) ----
SUTRADHAR_TTS__PROVIDER=piper             # piper | kokoro | stub
SUTRADHAR_TTS__VOICE=en_US-amy-medium
SUTRADHAR_TTS__SAMPLE_RATE=22050

# ---- Memory (SQLite + sqlite-vec) ----
SUTRADHAR_MEMORY__PROVIDER=sqlite         # sqlite | chroma | stub
SUTRADHAR_MEMORY__DB_PATH=data/sutradhar.db
SUTRADHAR_MEMORY__SHORT_TERM_TURNS=12

# ---- Transport ----
SUTRADHAR_TRANSPORT__DEFAULT=websocket    # websocket | webrtc | telephony_sim

# ---- Observability ----
SUTRADHAR_OBS__METRICS_ENABLED=true
SUTRADHAR_OBS__METRICS_PORT=9100
SUTRADHAR_OBS__TRACING_ENABLED=false      # true => export OTLP spans to Jaeger
SUTRADHAR_OBS__OTLP_ENDPOINT=http://127.0.0.1:4317

# ---- Reliability ----
SUTRADHAR_RELIABILITY__STAGE_TIMEOUT_MS=8000
SUTRADHAR_RELIABILITY__RETRY_MAX_ATTEMPTS=2
SUTRADHAR_RELIABILITY__CIRCUIT_FAIL_THRESHOLD=5
SUTRADHAR_RELIABILITY__FAILOVER_ENABLED=true

# ---- Mock backend (demo vertical: outbound lead qualification) ----
SUTRADHAR_BACKEND__BASE_URL=http://127.0.0.1:8090

# ---- Security ----
# Extra browser Origins allowed on the /ws voice socket (loopback always allowed).
# Empty = loopback-only, which blocks cross-site WebSocket hijacking.
# SUTRADHAR_SECURITY__ALLOWED_WS_ORIGINS=["https://ops.example.com"]
